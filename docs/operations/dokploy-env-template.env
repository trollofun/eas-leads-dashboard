# EAS Leads Dashboard — Dokploy env template
# Fill secrets from local migration/dokploy-*/app.env.actual. Do not commit real values.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# URLs
APP_URL=https://<dokploy-domain>
NEXTAUTH_URL=https://<dokploy-domain>
AUTH_TRUST_HOST=true

# Database
DATABASE_URL=postgresql://<user>:<password>@<dokploy-postgres-host>:5432/<database>

# Auth / signed email action links
NEXTAUTH_SECRET=<copy-from-current-or-generate>
LEAD_ACTION_SECRET=<copy-from-current-to-keep-old-email-links-valid>

# n8n bridge ingest
INGEST_API_KEY=<copy-from-current>
INGEST_HMAC_SECRET=<copy-from-current>

# Google Ads / Data Manager
GOOGLE_ADS_OPERATING_ACCOUNT_ID=7869775567
GOOGLE_ADS_LOGIN_ACCOUNT_ID=
GOOGLE_ADS_DEFAULT_CONVERSION_ACTION_ID=7672554854
GOOGLE_DATAMANAGER_VALIDATE_ONLY=false
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-service-account.json
GOOGLE_CONSENT_AD_USER_DATA=GRANTED
GOOGLE_CONSENT_AD_PERSONALIZATION=GRANTED

# Email: optional. Current source of truth for reception email is n8n Gmail, not dashboard SMTP.
RECEPTION_EMAIL=receptie@euroautoservice.ro
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=leads@euroautoservice.ro
